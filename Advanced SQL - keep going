## 4. Set Operations
```sql
SELECT customer_id FROM eu_customers
UNION          -- dedupes
SELECT customer_id FROM uk_customers;

SELECT customer_id FROM eu_customers
UNION ALL      -- keeps duplicates, faster
SELECT customer_id FROM uk_customers;

SELECT customer_id FROM active_customers
INTERSECT
SELECT customer_id FROM newsletter_subscribers;

SELECT customer_id FROM all_customers
EXCEPT         -- "MINUS" in Oracle/Teradata
SELECT customer_id FROM churned_customers;
```

